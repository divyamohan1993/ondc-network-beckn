# ============================================
# ONDC Platform Configuration
# ============================================
# Copy this file to .env and fill in the values
# Most values are auto-generated by autoconfig.sh
# ALL PASSWORDS ARE DYNAMICALLY GENERATED - NEVER USE STATIC VALUES

# --- Domain ---
DOMAIN=ondc.dmj.one

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ondc
POSTGRES_USER=ondc_admin
POSTGRES_PASSWORD=  # AUTO-GENERATED by autoconfig.sh

# --- DB Connection Pool ---
DB_POOL_MAX=20                       # Maximum DB connections per service
DB_POOL_IDLE_TIMEOUT=30000           # Close idle connections after 30s
DB_POOL_CONNECTION_TIMEOUT=5000      # Timeout waiting for available connection

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=  # AUTO-GENERATED by autoconfig.sh

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=ondc
RABBITMQ_PASSWORD=  # AUTO-GENERATED by autoconfig.sh
RABBITMQ_MANAGEMENT_PORT=15672

# --- Internal API Key (shared secret for inter-service auth) ---
INTERNAL_API_KEY=  # AUTO-GENERATED 64-byte random hex

# --- Registry Service ---
REGISTRY_PORT=3001
REGISTRY_SUBSCRIBER_ID=registry.ondc.dmj.one
REGISTRY_SIGNING_PRIVATE_KEY=  # AUTO-GENERATED Ed25519 key
REGISTRY_SIGNING_PUBLIC_KEY=   # AUTO-GENERATED Ed25519 key
REGISTRY_UNIQUE_KEY_ID=registry-key-01

# --- Gateway Service ---
GATEWAY_PORT=3002
GATEWAY_SUBSCRIBER_ID=gateway.ondc.dmj.one
GATEWAY_SIGNING_PRIVATE_KEY=  # AUTO-GENERATED Ed25519 key
GATEWAY_SIGNING_PUBLIC_KEY=   # AUTO-GENERATED Ed25519 key
GATEWAY_UNIQUE_KEY_ID=gateway-key-01

# --- BAP Adapter ---
BAP_PORT=3004
BAP_SUBSCRIBER_ID=bap.ondc.dmj.one
BAP_SIGNING_PRIVATE_KEY=  # AUTO-GENERATED Ed25519 key
BAP_SIGNING_PUBLIC_KEY=   # AUTO-GENERATED Ed25519 key
BAP_UNIQUE_KEY_ID=bap-key-01

# --- BPP Adapter ---
BPP_PORT=3005
BPP_SUBSCRIBER_ID=bpp.ondc.dmj.one
BPP_SIGNING_PRIVATE_KEY=  # AUTO-GENERATED Ed25519 key
BPP_SIGNING_PUBLIC_KEY=   # AUTO-GENERATED Ed25519 key
BPP_UNIQUE_KEY_ID=bpp-key-01

# --- Admin Dashboard ---
ADMIN_PORT=3003
ADMIN_EMAIL=admin@ondc.dmj.one
ADMIN_PASSWORD=  # AUTO-GENERATED, stored bcrypt-hashed in DB
NEXTAUTH_SECRET=  # AUTO-GENERATED 64-byte random
NEXTAUTH_URL=https://admin.ondc.dmj.one

# --- Docs Portal ---
DOCS_PORT=3000

# --- Secret Vault ---
VAULT_PORT=3006
VAULT_MASTER_KEY=  # AUTO-GENERATED 256-bit key for AES-256-GCM
VAULT_TOKEN_SECRET=  # AUTO-GENERATED HMAC signing secret
VAULT_URL=http://vault:3006

# --- Orchestrator ---
ORCHESTRATOR_PORT=3007
ORCHESTRATOR_URL=http://orchestrator:3007
DOCKER_SOCKET=/var/run/docker.sock

# --- Health Monitor ---
HEALTH_MONITOR_PORT=3008
HEALTH_MONITOR_URL=http://health-monitor:3008
HEALTH_CHECK_INTERVAL_MS=15000
RESPONSE_THRESHOLD_MS=5000

# --- Log Aggregator ---
LOG_AGGREGATOR_PORT=3009
LOG_AGGREGATOR_URL=http://log-aggregator:3009
LOG_RETENTION_DAYS=180               # CERT-In Directions 2022 minimum: 180 days

# --- Mock Server (Simulation) ---
MOCK_SERVER_PORT=3010

# --- Simulation Engine ---
SIMULATION_ENGINE_PORT=3011
SIMULATION_ENGINE_URL=http://simulation-engine:3011

# --- Network Settings ---
BECKN_CORE_VERSION=1.1.0
BECKN_COUNTRY=IND
DEFAULT_CITY=std:011
MAX_RESPONSE_TIME_MS=30000
SIGNATURE_TTL_SECONDS=300

# --- ONDC Compliance Middleware ---
RATE_LIMIT_MAX=100         # Max requests per subscriber per window
RATE_LIMIT_WINDOW=60       # Rate limit window in seconds
DEDUP_TTL=300              # Duplicate message_id TTL in seconds (5 min)

# --- Production Mode ---
PRODUCTION_MODE=false

# --- Password Rotation ---
PASSWORD_ROTATION_INTERVAL_HOURS=24
SIGNING_KEY_ROTATION_INTERVAL_DAYS=30

# ---------------------------------------------------------------------------
# Logging & Observability
# ---------------------------------------------------------------------------
LOG_LEVEL=info
ONDC_METRICS_URL=                    # ONDC observability endpoint URL (optional, enables metrics reporting)

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=                # Comma-separated allowed origins (e.g., https://admin.ondc.example.com)

# ---------------------------------------------------------------------------
# Registry Encryption (for subscribe challenge-response)
# ---------------------------------------------------------------------------
REGISTRY_ENCRYPTION_PRIVATE_KEY=     # AUTO-GENERATED - X25519 private key (base64)
REGISTRY_ENCRYPTION_PUBLIC_KEY=      # AUTO-GENERATED - X25519 public key (base64)

# ---------------------------------------------------------------------------
# Verification (production enforcement)
# ---------------------------------------------------------------------------
ENFORCE_DNS_VERIFICATION=false       # Set to "true" in production to require DNS TXT records
ENFORCE_CERT_VALIDATION=false        # Set to "true" in production to require valid SSL certs

# ---------------------------------------------------------------------------
# Logistics
# ---------------------------------------------------------------------------
LOGISTICS_ENABLED=false              # Enable logistics integration for BPP
LOGISTICS_GATEWAY_URL=               # Gateway URL for logistics search (e.g., https://gateway.ondc.org)
LOGISTICS_SELECTION_STRATEGY=cheapest  # cheapest | fastest | manual

# ---------------------------------------------------------------------------
# Internal Services Auth
# ---------------------------------------------------------------------------
VAULT_API_KEY=                       # AUTO-GENERATED - API key for vault service
ADMIN_TOKEN=                         # AUTO-GENERATED - Token for orchestrator admin API

# ---------------------------------------------------------------------------
# Health Monitor
# ---------------------------------------------------------------------------
CHECK_INTERVAL_MS=30000              # Health check interval

# ---------------------------------------------------------------------------
# Mock/Simulation (optional)
# ---------------------------------------------------------------------------
MOCK_AUTO_CONTINUE=false
MOCK_SERVER_URL=
BAP_ADAPTER_URL=

# ---------------------------------------------------------------------------
# Orchestrator
# ---------------------------------------------------------------------------
APP_MODE=development                 # development | production
RUNTIME_MODE=docker                  # docker | k8s | pm2

# ---------------------------------------------------------------------------
# Admin
# ---------------------------------------------------------------------------
ADMIN_NAME=admin

# ---------------------------------------------------------------------------
# Site Verification
# ---------------------------------------------------------------------------
ONDC_REQUEST_ID=                     # Request ID for ONDC site verification signing

# ---------------------------------------------------------------------------
# Vault
# ---------------------------------------------------------------------------
ROTATION_CHECK_INTERVAL_MS=3600000   # Key rotation check interval (1 hour)

# ---------------------------------------------------------------------------
# Stats
# ---------------------------------------------------------------------------
STATS_COLLECTION_INTERVAL_MS=60000   # Orchestrator stats collection interval

# ---------------------------------------------------------------------------
# Payment Gateway (Razorpay)
# ---------------------------------------------------------------------------
RAZORPAY_KEY_ID=                     # Razorpay API Key ID
RAZORPAY_KEY_SECRET=                 # Razorpay API Key Secret
RAZORPAY_WEBHOOK_SECRET=             # Razorpay webhook secret for signature verification
PAYMENT_GATEWAY=mock                 # razorpay | juspay | payU | mock

# ---------------------------------------------------------------------------
# Notifications - Email (SMTP)
# ---------------------------------------------------------------------------
SMTP_HOST=                           # SMTP server (e.g., smtp.gmail.com, email-smtp.ap-south-1.amazonaws.com)
SMTP_PORT=587                        # SMTP port (587 for STARTTLS, 465 for SSL)
SMTP_SECURE=false                    # true for port 465, false for 587
SMTP_USER=                           # SMTP username
SMTP_PASS=                           # SMTP password
SMTP_FROM=noreply@ondc.example.com   # From address

# ---------------------------------------------------------------------------
# Notifications - SMS
# ---------------------------------------------------------------------------
SMS_PROVIDER=mock                    # msg91 | twilio | mock
SMS_API_KEY=                         # MSG91 authkey or Twilio API key
SMS_SENDER_ID=ONDCSM                 # MSG91 sender ID (6 chars)
SMS_TEMPLATE_ID=                     # MSG91 template ID (for DLT compliance)
TWILIO_ACCOUNT_SID=                  # Twilio account SID
TWILIO_AUTH_TOKEN=                   # Twilio auth token
TWILIO_FROM_NUMBER=                  # Twilio phone number

# ---------------------------------------------------------------------------
# Push Notifications (Firebase Cloud Messaging)
# ---------------------------------------------------------------------------
FCM_PROJECT_ID=                      # Firebase project ID
FCM_SERVICE_ACCOUNT_KEY=             # Firebase service account JSON (base64 encoded)

# ---------------------------------------------------------------------------
# India Data (data.gov.in)
# ---------------------------------------------------------------------------
DATAGOVIN=                           # data.gov.in API key for pincode database seeding
                                     # Get yours at: https://data.gov.in/user/register

# ---------------------------------------------------------------------------
# Image Upload
# ---------------------------------------------------------------------------
UPLOAD_DIR=./uploads                 # Directory for uploaded images

# ---------------------------------------------------------------------------
# Post-Quantum Cryptography
# ---------------------------------------------------------------------------
PQ_CRYPTO_ENABLED=false              # Enable hybrid post-quantum signatures (Ed25519 + ML-DSA-65)
                                     # Requires @noble/post-quantum package. When false, classical-only mode.
                                     # When true, all new signatures use hybrid ed25519+ml-dsa-65 algorithm.
                                     # Verification always accepts both classical and hybrid headers.

# ---------------------------------------------------------------------------
# Indian Law Compliance
# ---------------------------------------------------------------------------
GRIEVANCE_OFFICER_NAME=              # Required: DPDPA 2023 & Consumer Protection Act 2019
GRIEVANCE_OFFICER_EMAIL=             # Required: DPDPA 2023 & Consumer Protection Act 2019
DATA_FIDUCIARY_NAME=                 # Required: DPDPA 2023 (your organization's legal name)
CERT_IN_REPORTING_EMAIL=incident@cert-in.org.in  # Official CERT-In incident reporting email

# ---------------------------------------------------------------------------
# ONDC Network Connection (set these to connect to real ONDC network)
# ---------------------------------------------------------------------------
# ONDC_REGISTRY_URL=                 # e.g., https://staging.registry.ondc.org or https://prod.registry.ondc.org
# ONDC_GATEWAY_URL=                  # e.g., https://staging.gateway.proteantech.in or https://prod.gateway.ondc.org
# ONDC_REGISTRY_PUBLIC_KEY=          # ONDC's X25519 encryption public key for subscribe challenge
#   Staging: MCowBQYDK2VuAyEAduMuZgmtpjdCuxv+Nc49K0cB6tL/Dj3HZetvVN7ZekM=
#   PreProd: MCowBQYDK2VuAyEAa9Wbpvd9SsrpOZFcynyt/TO3x0Yrqyys4NUGIvyxX2Q=
#   Prod:    MCowBQYDK2VuAyEAvVEyZY91O2yV8w8/CAwVDAnqIZDJJUPdLUUKwLo3K0M=
