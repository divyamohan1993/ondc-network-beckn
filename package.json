{
  "name": "ondc-network-beckn",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "db:migrate": "pnpm --filter shared db:migrate",
    "export:pramaan": "tsx scripts/src/export-pramaan-logs.ts",
    "seed:pincodes": "tsx scripts/src/seed-pincodes.ts"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "tar": ">=7.5.8",
      "lodash": ">=4.18.0",
      "minimatch": ">=3.1.4",
      "brace-expansion": ">=1.1.13",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "rollup": ">=4.59.0"
    }
  }
}
